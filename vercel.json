{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/generate-script", "destination": "/api/generate-script" },
    { "source": "/api/generate-image", "destination": "/api/generate-image" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
